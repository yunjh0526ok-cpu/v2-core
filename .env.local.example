# ─────────────────────────────────────────────────────────────────────────
#  Ethics-Core AI 2.0 — env template
#  이 파일을 복사해서 `.env.local` 로 저장한 뒤 값만 채워 넣으세요.
# ─────────────────────────────────────────────────────────────────────────

# 국가법령정보 공동활용 API  (https://open.law.go.kr)
# OC 값 = 신청 이메일 아이디(@ 앞)
LAW_API_KEY="여기에_OC값을_입력하세요"
LAW_API_BASE_URL="https://www.law.go.kr/DRF"

# Google Gemini API (선택 — 비워두면 규칙 기반 엔진으로 폴백)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# 관리자 비밀번호
ADMIN_PASSWORD="change-me"

# Socket.io 경로
SOCKET_PATH="/api/dialogue/socket.io"

# ─── Airtable (신청폼 자동화 메일 연동) ────────────────────────────────────
# Airtable Personal Access Token (https://airtable.com/create/tokens)
# → 권한: data.records:write  /  접근 범위: 해당 Base
AIRTABLE_API_KEY=""
# Base ID: Airtable URL 의 app... 부분  예) appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=""
# 레코드를 저장할 테이블명 (기본값: Applications)
AIRTABLE_TABLE_NAME="Applications"
